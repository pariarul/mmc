# Supabase Database Configuration
# Get these keys from your Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://jxdrtgtwttzjjrhdecgg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp4ZHJ0Z3R3dHR6ampyaGRlY2dnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY4MDA4MDksImV4cCI6MjA5MjM3NjgwOX0.FDQgEXl-dzX0qddHfMwNBcPVKZEz1slf20VE97DB3L8
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_private_key_bypasses_rls

# Prisma Supabase Connection Strings
# 1. DATABASE_URL: Connects through transaction pooling (PgBouncer port 6543)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
# 2. DIRECT_URL: Direct session connection (Standard PostgreSQL port 5432) for running migrations
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Session Cryptographic Key
# Put a long random string here to encrypt and sign session tokens
JWT_SECRET=mmc-secret-default-key-123456

# Single static Super Admin Credentials configuration
SUPER_ADMIN_EMAIL=allindiaccryncouncil@gmail.com
SUPER_ADMIN_PASSWORD=admin123

# Verification Email Service (Nodemailer SMTP Configuration)
# Note: If these keys are omitted, the portal automatically logs OTP codes
# in prominent boxes in the terminal (standard console fallback logging).
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
